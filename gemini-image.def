Bootstrap: docker
From: pytorch/pytorch:2.8.0-cuda12.9-cudnn9-devel

%files
    requirements.txt /app/

%post
    # Set correct permissions for /tmp
    chmod 1777 /tmp

    # Install basics + screen + libssl + openMP (used by llama-cpp)
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        python3 \
        python3-pip \
        curl \
        wget \
        screen \
        ca-certificates \
        libssl-dev \
        libgomp1 \
        libstdc++-11-dev
    ln -s /usr/bin/python3 /usr/bin/python

    # Compile gguf-split tool from llama.cpp repository
    echo "Building gguf-split tool..."
    git clone https://github.com/ggerganov/llama.cpp /tmp/llama.cpp
    cd /tmp/llama.cpp
    cmake -B build -DGGML_CUDA=OFF -DGGML_NATIVE=OFF -DBUILD_SHARED_LIBS=OFF
    cmake --build build --config Release -j --target llama-gguf-split
    cp build/bin/llama-gguf-split /usr/local/bin/gguf-split
    echo "Installing shared libraries..."
    find build -name "*.so*" -exec cp -v {} /usr/local/lib/ \;
    ldconfig
    cd /app
    rm -rf /tmp/llama.cpp

    # Python setup
    pip install uv
    mkdir -p /app
    cd /app
    uv venv
    uv pip install --upgrade -r /app/requirements.txt

%environment
    export PATH="/app/.venv/bin:$PATH"
    export SSL_CERT_FILE="/etc/ssl/certs/ca-certificates.crt"
    # export LD_LIBRARY_PATH="/usr/local/lib:$LD_LIBRARY_PATH" forgot to put it last time

%labels
    Author alban.bornet@unige.ch
    Version 0.2
    Description "Gemini container with vllm and native gguf-split"